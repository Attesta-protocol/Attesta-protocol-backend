# Copy to .env for local development. NEVER put user secrets here —
# the backend holds no secrets by design (see README: no-secrets invariant).

DATABASE_URL=postgres://attesta:attesta@localhost:5432/attesta
BIND_ADDR=0.0.0.0:8080

# Soroban RPC endpoint the indexer polls for contract events
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Comma-separated shielded-pool contract IDs to index (empty = none yet)
POOL_CONTRACT_IDS=

# Attestation registry contract ID (issuer registry mirror)
REGISTRY_CONTRACT_ID=

# Indexer poll interval in seconds
INDEXER_POLL_SECS=5

# Directory served by the prover-artifacts endpoints
ARTIFACTS_DIR=./artifacts

# Mailbox retention (docs/credential-mailbox.md): claimed deliveries are
# deleted N days after claiming, unclaimed ones M days after delivery.
# 0 disables that deletion (keep everything).
CREDENTIAL_RETENTION_CLAIMED_DAYS=30
CREDENTIAL_RETENTION_UNCLAIMED_DAYS=180

# Abuse protection — per-IP token buckets keyed on the socket peer address
# (defaults assume a directly exposed API). Any limit set to 0 is disabled,
# so private deployments can switch everything off.
RATE_LIMIT_READ_PER_SEC=50
RATE_LIMIT_READ_BURST=200
RATE_LIMIT_WRITE_PER_SEC=2
RATE_LIMIT_WRITE_BURST=20
RATE_LIMIT_SSE_PER_IP=10
RATE_LIMIT_SSE_GLOBAL=1000
RATE_LIMIT_ISSUER_DELIVERIES_PER_HOUR=600

# Comma-separated origins allowed for browser (CORS) access; empty = no
# CORS headers at all; * = any origin (the read API is public data).
CORS_ALLOWED_ORIGINS=

# Observability (docs/operations.md). /health/ready also fails when no
# indexer cursor moved within this window; 0 skips the check (API-only
# deployments). The indexer exports Prometheus metrics only when
# INDEXER_METRICS_ADDR is set (separate port, off by default).
READY_MAX_INDEXER_STALENESS_SECS=0
#INDEXER_METRICS_ADDR=0.0.0.0:9464

RUST_LOG=info,attesta_api=debug,attesta_indexer=debug
